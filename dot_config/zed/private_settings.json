// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "vim_mode": true,
  "vim": {
    "use_smartcase_find": true
  },
  "agent_servers": {
    "codex-acp": {
      "type": "registry"
    }
  },
  "language_models": {
    "openai_compatible": {
      "llama-cpp": {
        "api_url": "http://fwd:8080/v1",
        "available_models": [
          {
            "name": "qwen3-coder",
            "display_name": "Qwen3 Coder",
            "max_tokens": 262144,
            "max_output_tokens": 32768,
            "max_completion_tokens": 262144,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": true,
              "prompt_cache_key": false,
              "chat_completions": true
            }
          },
          {
            "name": "qwen3.6-35b",
            "display_name": "Qwen3.6 35B",
            "max_tokens": 131072,
            "max_output_tokens": 32768,
            "max_completion_tokens": 32768,
            "capabilities": {
              "tools": true,
              "images": true,
              "parallel_tool_calls": true,
              "prompt_cache_key": false,
              "chat_completions": true
            }
          },
          {
            "name": "qwen3.6-27b-q8",
            "display_name": "Qwen3.6 27B Q8",
            "max_tokens": 141072,
            "max_output_tokens": 32768,
            "max_completion_tokens": 32768,
            "capabilities": {
              "tools": true,
              "images": true,
              "parallel_tool_calls": true,
              "prompt_cache_key": false,
              "chat_completions": true
            }
          },
          {
            "name": "qwen3.6-27b-q4",
            "display_name": "Qwen3.6 27B Q4",
            "max_tokens": 141072,
            "max_output_tokens": 32768,
            "max_completion_tokens": 32768,
            "capabilities": {
              "tools": true,
              "images": true,
              "parallel_tool_calls": true,
              "prompt_cache_key": false,
              "chat_completions": true
            }
          },
          {
            "name": "gpt-oss-120b",
            "display_name": "GPT-OSS 120B",
            "max_tokens": 32768,
            "max_output_tokens": 8192,
            "max_completion_tokens": 32768,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": true,
              "prompt_cache_key": false,
              "chat_completions": true
            }
          }
        ]
      }
    }
  },
  "languages": {
    "YAML": {
      "tab_size": 2
    }
  },
  "ui_font_weight": 400.0,
  "ui_font_family": "MonoLisa Variable",
  "buffer_font_family": "MonoLisa Variable",
  "edit_predictions": {
    "open_ai_compatible_api": {
      "model": "",
      "api_url": "http://fwd:8080/v1"
    },
    "allow_data_collection": "no"
  },
  "terminal": {
    "font_size": 14.0,
    "font_family": "ZedMono Nerd Font Propo"
  },
  "outline_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "git": {
    "blame": {
      "show_avatar": false
    }
  },
  "bottom_dock_layout": "contained",
  "tab_bar": {
    "show": true
  },
  "title_bar": {
    "show_project_items": true,
    "show_onboarding_banner": false,
    "show_user_picture": false,
    "show_user_menu": false,
    "show_sign_in": false,
    "show_branch_name": true
  },
  "status_bar": {
    "active_language_button": true
  },
  "project_panel": {
    "dock": "left",
    "button": true
  },
  "which_key": {
    "delay_ms": null,
    "enabled": true
  },
  "use_smartcase_search": true,
  "inlay_hints": {
    "enabled": true
  },
  "collaboration_panel": {
    "dock": "left",
    "button": false
  },
  "toolbar": {
    "agent_review": true
  },
  "gutter": {
    "line_numbers": false
  },
  "auto_signature_help": true,
  "restore_on_startup": "launchpad",
  "agent": {
    "dock": "right",
    "model_parameters": [],
    "enable_feedback": false
  },
  "disable_ai": false,
  "telemetry": {
    "metrics": false,
    "diagnostics": false
  },
  "ui_font_size": 15.0,
  "buffer_font_size": 15.0,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Tokyo Night"
  },
  "lsp": {
    "terraform-ls": {
      "initialization_options": {
        "experimentalFeatures": {
          "prefillRequiredFields": true
        }
      }
    },
    "gopls": {
      "initialization_options": {
        "gofumpt": true,
        "hints": {
          "assignVariableTypes": true,
          "compositeLiteralFields": true,
          "compositeLiteralTypes": true,
          "constantValues": true,
          "functionTypeParameters": true,
          "parameterNames": true,
          "rangeVariableTypes": true
        }
      }
    },
    "yaml-language-server": {
      "settings": {
        "yaml": {
          "schemas": {
            "http://json.schemastore.org/github-workflow": ".github/workflows/*",
            "http://json.schemastore.org/github-action": ".github/action.{yml,yaml}",
            // "https://raw.githubusercontent.com/microsoft/azure-pipelines-vscode/master/service-schema.json": "azure-pipelines*.{yml,yaml}",
            "https://raw.githubusercontent.com/ansible/ansible-lint/main/src/ansiblelint/schemas/ansible.json#/$defs/tasks": "roles/tasks/*.{yml,yaml}",
            "https://raw.githubusercontent.com/ansible/ansible-lint/main/src/ansiblelint/schemas/ansible.json#/$defs/playbook": "*play*.{yml,yaml}",
            "http://json.schemastore.org/prettierrc": ".prettierrc.{yml,yaml}",
            "http://json.schemastore.org/kustomization": "kustomization.{yml,yaml}",
            "http://json.schemastore.org/chart": "Chart.{yml,yaml}",
            "https://json.schemastore.org/dependabot-v2": ".github/dependabot.{yml,yaml}",
            "https://gitlab.com/gitlab-org/gitlab/-/raw/master/app/assets/javascripts/editor/schema/ci.json": "*gitlab-ci*.{yml,yaml}",
            "https://raw.githubusercontent.com/OAI/OpenAPI-Specification/main/schemas/v3.1/schema.json": "*api*.{yml,yaml}",
            "https://raw.githubusercontent.com/compose-spec/compose-spec/master/schema/compose-spec.json": "*compose*.{yml,yaml}",
            "https://raw.githubusercontent.com/argoproj/argo-workflows/master/api/jsonschema/schema.json": "*flow*.{yml,yaml}",
            "https://taskfile.dev/schema.json": "Taskfile.{yml,yaml}"
          }
        }
      }
    }
  }
}
