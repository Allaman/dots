title = " "
theme = "Gruvbox Dark"
macos-titlebar-style = hidden
copy-on-select = true
adjust-cell-height = 15%
font-family = "IBM Plex Mono"
font-size = 15
mouse-hide-while-typing = true
shell-integration = "zsh"
scrollback-limit = 100000
window-save-state = never
maximize = false
quit-after-last-window-closed = true
auto-update = check

# map super+p to meta+n for tmux
keybind = super+n=text:\x1b[110;3u
# super+n map to meta+p for tmux
keybind = super+p=text:\x1b[112;3u
# for claude new line (CSI-u Shift+Enter; works through tmux extended-keys)
keybind = shift+enter=text:\x1b[13;2u

