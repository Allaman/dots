# command -v direnv > /dev/null 2>&1 && eval "$(direnv hook zsh)"

export GOPATH=$HOME/.local/share/go 
export GOBIN=$HOME/.local/share/go/bin
export PATH=$PATH:$GOBIN
[ -d $HOME/.cargo/bin ] && export PATH=$PATH:~/.cargo/bin

[ -d "/Applications/Sublime Text.app/Contents/SharedSupport/bin" ] && export PATH="$PATH:/Applications/Sublime Text.app/Contents/SharedSupport/bin"
[ -d "/Applications/Sublime Merge.app/Contents/SharedSupport/bin" ] && export PATH="$PATH:/Applications/Sublime Merge.app/Contents/SharedSupport/bin"
[ -d "/Applications/Obsidian.app/Contents/MacOS" ] && export PATH="$PATH:/Applications/Obsidian.app/Contents/MacOS"

source $HOME/.fzf.zsh

export _ZO_DATA_DIR=$HOME/data/.zoxide
export _ZO_FZF_OPTS="
  --height 50%
  --layout reverse
  --border rounded
  --no-separator
  --preview-border line
  --preview 'eza --tree --level 2 --color=always {2..} 2>/dev/null || ls -la {2..}'
  --preview-window 'right,50%'
  --bind 'ctrl-p:toggle-preview'
  --bind 'ctrl-o:execute(nvim {2..})'
  --bind 'ctrl-y:execute(echo {2..} | pbcopy)'
"
command -v zoxide >/dev/null 2>&1 && eval "$(zoxide init zsh)"

command -v atuin >/dev/null 2>&1 && eval "$(atuin init zsh --disable-up-arrow)"

source $HOME/.shell/fast-syntax-Highlighting/fast-syntax-highlighting.plugin.zsh

if [ "$TERM_PROGRAM" != "Apple_Terminal" ]; then
  eval "$(oh-my-posh init zsh --config $HOME/.config/oh-my-posh/config.toml)"
fi

# enable zmv - an enhanced file mover
# https://zsh.sourceforge.io/Doc/Release/User-Contributions.html#index-zmv
autoload zmv

