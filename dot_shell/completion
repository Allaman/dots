# https://thevaluable.dev/zsh-completion-guide-examples/

[ -d /opt/homebrew/share/zsh/site-functions ] && fpath=(/opt/homebrew/share/zsh/site-functions $fpath)
[ -d $HOME/.shell/zsh-completions/ ] && fpath=($HOME/.shell/zsh-completions/src $fpath)

# Must be loaded before compinit
zmodload zsh/complist
bindkey -M menuselect 'h' vi-backward-char
bindkey -M menuselect 'k' vi-up-line-or-history
bindkey -M menuselect 'j' vi-down-line-or-history
bindkey -M menuselect 'l' vi-forward-char
bindkey -M menuselect '^[[Z' reverse-menu-complete  # Shift-Tab goes backward

bindkey '^[[Z' reverse-menu-complete  # Shift-Tab goes backward
autoload -U compinit; compinit
_comp_options+=(globdots)  # Include hidden files

setopt AUTO_LIST         # List choices on ambiguous completion
setopt COMPLETE_IN_WORD  # Complete from both ends of a word
# setopt MENU_COMPLETE   # Auto-select first match (aggressive — enable if you want it)

# Completers: fuzzy match as fallback
zstyle ':completion:*' completer _complete _approximate

# Cache slow completions
zstyle ':completion:*' use-cache on
zstyle ':completion:*' cache-path "$XDG_CACHE_HOME/zsh/.zcompcache"

# Menu selection
zstyle ':completion:*' menu select

# Colored output
zstyle ':completion:*:*:*:*:corrections'  format '%F{yellow}!- %d (errors: %e) -!%f'
zstyle ':completion:*:*:*:*:descriptions' format '%F{blue}-- %D %d --%f'
zstyle ':completion:*:*:*:*:messages'     format '%F{purple} -- %d --%f'
zstyle ':completion:*:*:*:*:warnings'     format '%F{red}-- no matches found --%f'
zstyle ':completion:*:*:*:*:default'      list-colors ${(s.:.)LS_COLORS}

# Group completions by tag
zstyle ':completion:*' group-name ''
zstyle ':completion:*:*:-command-:*:*' group-order aliases builtins functions commands

# Smart case matching
zstyle ':completion:*' matcher-list '' 'm:{a-zA-Z}={A-Za-z}' 'r:|[._-]=* r:|=*' 'l:|=* r:|=*'
zstyle ':completion:*' keep-prefix true

# Directories first, then alphabetical
zstyle ':completion:*' list-dirs-first yes

# cd: prefer local dirs
zstyle ':completion:*:*:cd:*' tag-order local-directories directory-stack path-directories

# SSH host completion from known_hosts
zstyle -e ':completion:*:(ssh|scp|sftp|rsh|rsync):hosts' hosts \
  'reply=(${=${${(f)"$(cat {/etc/ssh_,~/.ssh/known_}hosts(|2)(N) /dev/null)"}%%[# ]*}//,/ })'

