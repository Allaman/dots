# allows me to always type "make" and I do not have to check
# the repo if a Taskfile or a Makefile is available
make_wrap() {
  # Taskfile is preferred
  if [ -f Taskfile.yml ]; then
    echo "using task"
    task $@
  elif [ -f Makefile ]; then
    echo "Using make"
    \make $@ # to prevent infinite recursion
  else
    echo "No Taskfile or Makefile found"
  fi
}

# cd between git worktrees
cdwt() {
  local target=$(git worktree list | fzf --height=40% | awk '{print $1}')
  [ -n "$target" ] && cd "$target"
}
