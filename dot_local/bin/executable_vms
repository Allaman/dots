#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "usage: $(basename "$0") <command> [args]"
  echo "  start               start VM for current directory and SSH in (clones from debian-base if needed)"
  echo "  stop <vm>           stop a running VM"
  echo "  ssh <vm>            SSH into a running VM"
  echo "  list                list all VMs"
  echo "  clone <src> <name>  clone a VM"
  echo "  delete <vm>         delete a VM"
  echo "  destroy <vm>        stop and delete a VM"
  exit 1
}

[[ $# -lt 1 ]] && usage
CMD=$1
shift

current_vm() {
  echo "$(basename "$(dirname "$PWD")")_$(basename "$PWD")"
}

wait_for_ssh() {
  local vm_name="$1"
  local ip="$2"
  local max_attempts="${3:-30}"
  local timeout_msg="${4:-SSH not ready}"
  
  if [[ -z "$ip" ]]; then
    echo "error: no IP address assigned to $vm_name" >&2
    return 1
  fi
  
  echo "waiting for SSH on $ip..."
  local attempt=0
  until nc -z "$ip" 22 2>/dev/null; do
    attempt=$((attempt + 1))
    if [[ $attempt -ge $max_attempts ]]; then
      echo "error: connection timeout after ${max_attempts}s. $timeout_msg on $ip" >&2
      return 1
    fi
    sleep 1
  done
  
  if [[ "${VERBOSE:-0}" == "1" ]] || [[ "$CMD" == "start" ]]; then
    echo "SSH available at $ip"
  fi
  return 0
}

vm_exists() {
  tart list 2>/dev/null | grep -qw "$1"
}

is_running() {
  tart list 2>/dev/null | grep -w "$1" | grep -qi "running"
}

case "$CMD" in
start)
  VM=$(current_vm)
  if ! vm_exists "$VM"; then
    echo "cloning debian-base as $VM..."
    tart clone debian-base "$VM"
  fi
  if ! is_running "$VM"; then
    mkdir -p ~/.pi/projects
    echo "$PWD" >~/.pi/projects/"$VM"
    nohup tart run --dir=pi:~/.pi/ --dir=project:"$PWD" --no-graphics "$VM" &>/dev/null &
    echo "started $VM, waiting for SSH..."
  fi
  IP=$(tart ip "$VM" --wait 60) || { echo "error: failed to get IP for $VM" >&2; exit 1; }
  if ! wait_for_ssh "$VM" "$IP" 30 "SSH not ready after VM boot"; then
    echo "tip: check if the VM booted correctly with 'tart console $VM'" >&2
    exit 1
  fi
  exec ssh -o StrictHostKeyChecking=no admin@"$IP"
  ;;
stop)
  [[ $# -lt 1 ]] && usage
  tart stop "$1"
  rm -f ~/.pi/projects/"$1"
  ;;
ssh)
  [[ $# -lt 1 ]] && usage
  if ! is_running "$1"; then
    echo "error: VM '$1' is not running" >&2
    exit 1
  fi
  IP=$(tart ip "$1" --wait 30) || { echo "error: failed to get IP for $1" >&2; exit 1; }
  if ! wait_for_ssh "$1" "$IP" 10 "SSH not responding"; then
    echo "tip: check if the VM is responsive with 'tart console $1'" >&2
    exit 1
  fi
  exec ssh -o StrictHostKeyChecking=no admin@"$IP"
  ;;
list)
  tart list
  ;;
clone)
  [[ $# -lt 2 ]] && usage
  tart clone "$1" "$2"
  ;;
delete)
  [[ $# -lt 1 ]] && usage
  if is_running "$1"; then
    echo "error: VM '$1' is running; stop it first or use 'destroy'" >&2
    exit 1
  fi
  tart delete "$1"
  ;;
destroy)
  [[ $# -lt 1 ]] && usage
  if is_running "$1"; then tart stop "$1"; fi
  rm -f ~/.pi/projects/"$1"
  tart delete "$1"
  ;;
*)
  usage
  ;;
esac

# vim: set filetype=sh :
